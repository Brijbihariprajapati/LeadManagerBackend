PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/lead_management

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Allowed browser origins (CORS). Comma-separated for multiple (e.g. Next + Vite dev).
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173

# Optional: seed first admin (npm run seed)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeMe123456
